<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="330dp"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/content_header_surface"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:letterSpacing="0.08"
            android:text="PROFILE SELECTION"
            android:textAllCaps="true"
            android:textColor="@color/settings_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/SProfile"
                style="@style/ComboBox"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:textColor="@color/settings_text_primary"
                android:spinnerMode="dialog"/>

            <ImageView
                android:id="@+id/BTSettings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/icon_settings"
                app:tint="@color/settings_icon_tint" />
        </LinearLayout>

        <View android:layout_marginBottom="16dp" android:background="@color/settings_outline" android:layout_width="match_parent" android:layout_height="1dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:letterSpacing="0.08"
            android:text="TOUCHSCREEN OVERLAY"
            android:textAllCaps="true"
            android:textColor="@color/settings_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/CBShowTouchscreenControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:textColor="@color/settings_text_primary"
            android:buttonTint="@color/settings_icon_tint"
            android:text="@string/show_touchscreen_controls" />

        <CheckBox
            android:id="@+id/CBEnableTimeout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/settings_text_primary"
            android:buttonTint="@color/settings_icon_tint"
            android:text="@string/enable_touchscreen_timeout"
            android:checked="false" />

        <CheckBox
            android:id="@+id/CBEnableHaptics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/settings_text_primary"
            android:buttonTint="@color/settings_icon_tint"
            android:text="@string/enable_touchscreen_haptics"
            android:checked="false" />

    </LinearLayout>
</LinearLayout>