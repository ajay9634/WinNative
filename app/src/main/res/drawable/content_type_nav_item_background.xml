<?xml version="1.0" encoding="utf-8"?>
<!-- Tab chip background for component type navigation on the Components screen. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/settings_chip_selected" />
            <stroke
                android:width="1dp"
                android:color="@color/settings_chip_selected_stroke" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/settings_chip_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/settings_outline" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
